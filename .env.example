# --- Database / cache ---
DATABASE_URL=postgres://trader:trader@localhost:5432/trading
REDIS_URL=redis://localhost:6379

# --- LLM ---
ANTHROPIC_API_KEY=
# Default analyst model (a current Sonnet-class model)
ANTHROPIC_MODEL=claude-sonnet-5

# --- Interactive Brokers gateway ---
IB_GATEWAY_HOST=localhost
IB_GATEWAY_PORT=4002           # 4002 paper, 4001 live
IB_ACCOUNT_ID=                 # DU... paper account
IB_CLIENT_ID=10                # TWS/Gateway API client id (unique per connection)
IB_USERNAME=                   # consumed by ib-gateway container only (-> TWS_USERID)
IB_PASSWORD=                   # consumed by ib-gateway container only (-> TWS_PASSWORD)

# --- Market data (T0.5) ---
MARKET_DATA_ENABLED=false      # true => open live IB connection + realtime bars at boot
MARKET_DATA_TICKERS=QUAL,SPHB,SPY
IB_PACING_INTERVAL_MS=10000    # min spacing between historical requests (pacing guard)
IB_RECONNECT_BASE_MS=1000      # reconnect backoff base
IB_RECONNECT_MAX_MS=30000      # reconnect backoff cap

# --- IB gateway container (gnzsnz/ib-gateway) tuning ---
TRADING_MODE=paper             # paper | live | both
READ_ONLY_API=no
TWOFA_TIMEOUT_ACTION=restart
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
AUTO_RESTART_TIME=11:59 PM     # daily gateway restart (container TZ)
BYPASS_WARNING=yes
TWS_ACCEPT_INCOMING=accept
EXISTING_SESSION_DETECTED_ACTION=primary
TIME_ZONE=Etc/UTC
VNC_SERVER_PASSWORD=           # set to enable VNC debugging (internal network only)

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- App ---
APP_AUTH_SECRET=
KILL_SWITCH_DAILY_LOSS_PCT=3
