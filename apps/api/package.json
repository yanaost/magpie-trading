{
  "name": "@magpie/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json && (tsc -w -p tsconfig.json --preserveWatchOutput & node --watch dist/main.js)",
    "start": "node dist/main.js",
    "ingest:backfill": "node dist/ingest/backfill.js",
    "ingest:backfill:dev": "tsx src/ingest/backfill.ts",
    "smoke:llm": "tsx src/llm/smoke.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@magpie/core": "workspace:*",
    "@magpie/db": "workspace:*",
    "@magpie/strategies": "workspace:*",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/websockets": "^10.4.15",
    "@stoqey/ib": "^1.6.3",
    "bullmq": "^5.34.6",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "nestjs-pino": "^4.2.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/node": "^22.10.5",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
